          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "clamp_max(sum by (pod, namespace) (container_memory_working_set_bytes{namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}) / sum by (pod, namespace) (kube_pod_container_resource_limits{resource=\"memory\", namespace=~\"$namespace\"}), 1) or ((sum by (pod, namespace) (container_memory_working_set_bytes{namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}) * 0 + 1.01) unless sum by (pod, namespace) (kube_pod_container_resource_limits{resource=\"memory\", namespace=~\"$namespace\"}))",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "L"
        }
