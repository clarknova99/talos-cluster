        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "count by (pod, namespace) (kube_pod_container_info{namespace=~\"$namespace\"})",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "J"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "exemplar": false,
          "expr": "clamp_max(sum by (pod, namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}[5m])) / sum by (pod, namespace) (kube_pod_container_resource_limits{resource=\"cpu\", namespace=~\"$namespace\"}), 1) or ((sum by (pod, namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}[5m])) * 0 + 1.01) unless sum by (pod, namespace) (kube_pod_container_resource_limits{resource=\"cpu\", namespace=~\"$namespace\"}))",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "K"
        },
